<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_montae_studio" model="ir.module.category">
        <field name="name">Montae Studio</field>
    </record>

    <record id="group_montae_client" model="res.groups">
        <field name="name">Client</field>
        <field name="category_id" ref="module_montae_studio"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="group_montae_staff" model="res.groups">
        <field name="name">Staff</field>
        <field name="category_id" ref="module_montae_studio"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_montae_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_montae_studio"/>
        <field name="implied_ids" eval="[(4, ref('group_montae_staff'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
