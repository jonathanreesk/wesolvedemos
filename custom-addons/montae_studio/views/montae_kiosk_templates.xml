<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="kiosk_home" name="Montae Kiosk">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-set="head_kiosk">
                <link rel="stylesheet" href="/montae_studio/static/src/css/montae_kiosk.css"/>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.383.0/umd/lucide.min.js"></script>
            </t>
            <t t-set="additional_title">Check In — Montae Studio</t>
            <t t-set="head" t-value="head_kiosk"/>
            <body class="montae-kiosk">
                <div class="kiosk-wrap">
                    <div class="kiosk-logo">MONTAE</div>
                    <h1 class="kiosk-heading">Welcome</h1>
                    <p class="kiosk-sub">Enter your name or email to check in</p>

                    <div class="kiosk-search">
                        <input id="kiosk-query" class="kiosk-input" type="text"
                               placeholder="Name or email…" autocomplete="off"/>
                        <button id="kiosk-search-btn" class="kiosk-btn">
                            <i data-lucide="search"></i>
                        </button>
                    </div>

                    <div id="kiosk-results" class="kiosk-results" style="display:none;"></div>
                    <div id="kiosk-confirm" class="kiosk-confirm" style="display:none;">
                        <i data-lucide="check-circle" class="kiosk-check-icon"></i>
                        <h2 id="kiosk-confirm-name"></h2>
                        <p id="kiosk-confirm-session"></p>
                        <button id="kiosk-reset" class="kiosk-btn kiosk-btn--ghost">Check in another guest</button>
                    </div>
                </div>
                <script src="/montae_studio/static/src/js/montae_kiosk.js"></script>
                <script>lucide.createIcons();</script>
            </body>
        </t>
    </template>
</odoo>
