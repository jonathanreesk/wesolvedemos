<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="staff_calendar" name="Montae Staff Day-Planner">
        <t t-call="website.layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-set="head_staff">
                <link rel="stylesheet" href="/montae_studio/static/src/css/montae_portal.css"/>
                <link rel="stylesheet" href="/montae_studio/static/src/css/montae_staff_calendar.css"/>
                <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
            </t>
            <t t-set="additional_title">Staff Calendar — Montae Studio</t>
            <t t-set="head" t-value="head_staff"/>
            <body class="montae-portal montae-staff">

                <header class="montae-header">
                    <a href="/studio" class="montae-logo">MONTAE</a>
                    <nav class="montae-nav">
                        <a href="/studio/staff/calendar" class="montae-nav--active">Day Planner</a>
                        <a href="/odoo/montae-studio">
                            <i data-lucide="layout-dashboard"></i> Back-end
                        </a>
                        <a href="/web/session/logout">Sign Out</a>
                    </nav>
                </header>

                <main class="montae-container montae-staff-cal-page"
                      data-today="current_date"
                      t-att-data-today="current_date">

                    <!-- Date navigation -->
                    <div class="staff-cal-nav">
                        <a t-attf-href="/studio/staff/calendar?date=#{prev_date}"
                           class="montae-btn montae-btn--ghost">
                            <i data-lucide="chevron-left"></i>
                        </a>
                        <h1 class="staff-cal-date" t-esc="day_label"/>
                        <a t-attf-href="/studio/staff/calendar?date=#{next_date}"
                           class="montae-btn montae-btn--ghost">
                            <i data-lucide="chevron-right"></i>
                        </a>
                        <a t-attf-href="/studio/staff/calendar?date=#{today}"
                           t-attf-class="montae-btn montae-btn--ghost#{' montae-btn--active' if current_date == today else ''}">
                            Today
                        </a>
                    </div>

                    <!-- Grid container — JS fills this in -->
                    <div class="staff-cal-grid-wrap">
                        <div id="staff-cal-grid"
                             class="staff-cal-grid"
                             t-att-data-date="current_date"
                             t-att-data-resources="','.join(str(r.id) for r in resources)">
                            <!-- Columns built by JS after fetching bookings -->
                            <div class="staff-cal-loading">
                                <i data-lucide="loader" class="spin"></i> Loading…
                            </div>
                        </div>
                    </div>
                </main>

                <!-- Booking detail drawer -->
                <aside id="staff-drawer" class="staff-drawer" style="display:none;">
                    <button id="staff-drawer-close" class="staff-drawer-close">
                        <i data-lucide="x"></i>
                    </button>
                    <div id="staff-drawer-content" class="staff-drawer-content"></div>
                </aside>

                <!-- New booking modal -->
                <div id="staff-modal" class="staff-modal-overlay" style="display:none;">
                    <div class="staff-modal">
                        <div class="staff-modal-header">
                            <h2>New Booking</h2>
                            <button id="staff-modal-close" class="staff-drawer-close">
                                <i data-lucide="x"></i>
                            </button>
                        </div>
                        <div class="staff-modal-body">
                            <label>Client</label>
                            <div class="montae-autocomplete">
                                <input id="modal-client-search" class="montae-input"
                                       type="text" placeholder="Search by name or email…" autocomplete="off"/>
                                <ul id="modal-client-results" class="montae-autocomplete-list" style="display:none;"></ul>
                                <input id="modal-client-id" type="hidden"/>
                            </div>

                            <label>Session Type</label>
                            <input id="modal-session-type" class="montae-input" type="text"
                                   placeholder="e.g. Infrared 60min"/>

                            <label>Start Time</label>
                            <input id="modal-start-time" class="montae-input" type="datetime-local"/>

                            <label>Duration (minutes)</label>
                            <select id="modal-duration" class="montae-select">
                                <option value="30">30 min</option>
                                <option value="60" selected="1">60 min</option>
                                <option value="90">90 min</option>
                            </select>

                            <label>Notes</label>
                            <textarea id="modal-notes" class="montae-input" rows="3"></textarea>

                            <input id="modal-resource-id" type="hidden"/>
                        </div>
                        <div class="staff-modal-footer">
                            <button id="modal-cancel-btn" class="montae-btn montae-btn--ghost">Cancel</button>
                            <button id="modal-confirm-btn" class="montae-btn montae-btn--primary">Create Booking</button>
                        </div>
                    </div>
                </div>

                <script t-att-src="'/montae_studio/static/src/js/montae_staff_calendar.js'"/>
                <script>
                    // Pass resource metadata to JS
                    window.MONTAE_RESOURCES = [
                        <t t-foreach="resources" t-as="res">
                        {
                            id: <t t-out="res.id"/>,
                            name: "<t t-out="res.name.replace('\"', '&quot;')"/>",
                            open_time: <t t-out="res.open_time"/>,
                            close_time: <t t-out="res.close_time"/>
                        }<t t-if="not res_last">,</t>
                        </t>
                    ];
                    lucide.createIcons();
                </script>
            </body>
        </t>
    </template>
</odoo>
