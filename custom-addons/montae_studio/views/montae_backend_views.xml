<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Plans ─────────────────────────────────────────────────── -->
    <record id="view_montae_plan_list" model="ir.ui.view">
        <field name="name">montae.plan.list</field>
        <field name="model">montae.plan</field>
        <field name="arch" type="xml">
            <list string="Plans">
                <field name="name"/>
                <field name="code"/>
                <field name="price"/>
                <field name="billing_period"/>
                <field name="session_credits"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_montae_plan_form" model="ir.ui.view">
        <field name="name">montae.plan.form</field>
        <field name="model">montae.plan</field>
        <field name="arch" type="xml">
            <form string="Membership Plan">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="price"/>
                        <field name="billing_period"/>
                        <field name="session_credits"/>
                        <field name="stripe_price_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_montae_plan" model="ir.actions.act_window">
        <field name="name">Membership Plans</field>
        <field name="res_model">montae.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Subscriptions ─────────────────────────────────────────── -->
    <record id="view_montae_subscription_list" model="ir.ui.view">
        <field name="name">montae.subscription.list</field>
        <field name="model">montae.subscription</field>
        <field name="arch" type="xml">
            <list string="Subscriptions">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="plan_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'paused'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="date_start"/>
                <field name="next_billing_date"/>
                <field name="credit_balance"/>
            </list>
        </field>
    </record>

    <record id="view_montae_subscription_form" model="ir.ui.view">
        <field name="name">montae.subscription.form</field>
        <field name="model">montae.subscription</field>
        <field name="arch" type="xml">
            <form string="Subscription">
                <header>
                    <button name="action_activate" string="Activate" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,paused,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="plan_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="next_billing_date"/>
                        <field name="credit_balance"/>
                        <field name="stripe_subscription_id"/>
                        <field name="stripe_customer_id"/>
                    </group>
                    <notebook>
                        <page string="Bookings">
                            <field name="booking_ids" readonly="1"/>
                        </page>
                        <page string="Credit Log">
                            <field name="credit_log_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_montae_subscription" model="ir.actions.act_window">
        <field name="name">Subscriptions</field>
        <field name="res_model">montae.subscription</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Resources ─────────────────────────────────────────────── -->
    <record id="view_montae_resource_list" model="ir.ui.view">
        <field name="name">montae.resource.list</field>
        <field name="model">montae.resource</field>
        <field name="arch" type="xml">
            <list string="Resources">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="resource_type"/>
                <field name="capacity"/>
                <field name="open_time" widget="float_time"/>
                <field name="close_time" widget="float_time"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_montae_resource" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">montae.resource</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Bookings ───────────────────────────────────────────────── -->
    <record id="view_montae_booking_list" model="ir.ui.view">
        <field name="name">montae.booking.list</field>
        <field name="model">montae.booking</field>
        <field name="arch" type="xml">
            <list string="Bookings">
                <field name="datetime_start"/>
                <field name="partner_id"/>
                <field name="session_type"/>
                <field name="resource_id"/>
                <field name="duration"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('checked_in','completed')"
                       decoration-warning="state == 'confirmed'"
                       decoration-danger="state in ('cancelled','no_show')"/>
            </list>
        </field>
    </record>

    <record id="view_montae_booking_form" model="ir.ui.view">
        <field name="name">montae.booking.form</field>
        <field name="model">montae.booking</field>
        <field name="arch" type="xml">
            <form string="Booking">
                <header>
                    <button name="action_check_in" string="Check In" type="object"
                            invisible="state != 'confirmed'" class="btn-primary"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'checked_in'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state not in ('confirmed','checked_in')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="confirmed,checked_in,completed"/>
                </header>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="subscription_id"/>
                        <field name="resource_id"/>
                        <field name="session_type"/>
                        <field name="datetime_start"/>
                        <field name="datetime_end"/>
                        <field name="duration"/>
                        <field name="credits_used"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_montae_booking_calendar" model="ir.ui.view">
        <field name="name">montae.booking.calendar</field>
        <field name="model">montae.booking</field>
        <field name="arch" type="xml">
            <calendar string="Bookings" date_start="datetime_start" date_stop="datetime_end"
                      color="resource_id" mode="week">
                <field name="partner_id"/>
                <field name="session_type"/>
                <field name="resource_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="action_montae_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">montae.booking</field>
        <field name="view_mode">calendar,list,form</field>
    </record>
</odoo>
